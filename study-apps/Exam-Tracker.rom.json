{
  "format": "romio-app",
  "version": 1,
  "exported_at": "2026-07-16T00:00:00.000Z",
  "app": {
    "name": "Exam Tracker",
    "description": "Plan for exams — dates, weight, study status, target and actual grades.",
    "type": "Records",
    "icon": "ti-certificate",
    "color": "#dc2626",
    "fields": [
      { "id": "f_name", "label": "Exam", "type": "text", "required": true, "hidden": false, "config": {} },
      { "id": "f_subject", "label": "Subject", "type": "text", "required": false, "hidden": false, "config": {} },
      { "id": "f_when", "label": "Exam date", "type": "date", "required": false, "hidden": false, "config": { "time": true } },
      { "id": "f_weight", "label": "Weight", "type": "number", "required": false, "hidden": false, "config": { "min": 0, "max": 100, "unit": "%" } },
      { "id": "f_status", "label": "Study status", "type": "status", "required": false, "hidden": false, "config": { "options": [
        { "id": "not", "label": "Not studied", "color": "#6b7280" },
        { "id": "studying", "label": "Studying", "color": "#d97706" },
        { "id": "ready", "label": "Ready", "color": "#16a34a" }
      ] } },
      { "id": "f_target", "label": "Target grade", "type": "number", "required": false, "hidden": false, "config": { "min": 0, "max": 100, "unit": "%" } },
      { "id": "f_score", "label": "Actual grade", "type": "number", "required": false, "hidden": false, "config": { "min": 0, "max": 100, "decimals": 1, "unit": "%" } },
      { "id": "f_room", "label": "Location", "type": "text", "required": false, "hidden": false, "config": {} }
    ],
    "automations": [
      { "id": "a_ready", "name": "Ready to go", "enabled": true, "trigger": { "event": "field_is", "fieldId": "f_status", "value": "ready" }, "actions": [ { "type": "notify", "message": "Exam marked ready — do a final review the night before." } ] },
      { "id": "a_lowscore", "name": "Low score review", "enabled": true, "trigger": { "event": "field_is", "fieldId": "f_score", "op": "<", "value": "75" }, "actions": [ { "type": "notify", "message": "An exam scored under 75% — review that topic." } ] }
    ],
    "items": [
      { "id": "i_1", "values": { "f_name": "Midterm", "f_subject": "Biology", "f_when": "2026-07-25T10:00", "f_weight": 30, "f_status": "studying", "f_target": 90, "f_room": "Hall 1" } },
      { "id": "i_2", "values": { "f_name": "Quiz 3", "f_subject": "Chemistry", "f_when": "2026-07-19T14:00", "f_weight": 10, "f_status": "ready", "f_target": 85, "f_score": 88, "f_room": "Room 12" } }
    ]
  }
