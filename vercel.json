{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/tabulation", "destination": "/tabulation/index.html" },
    { "source": "/tabulation/", "destination": "/tabulation/index.html" },
    { "source": "/tabulation/master", "destination": "/tabulation/index.html" },
    { "source": "/tabulation/judge", "destination": "/tabulation/index.html" },
    { "source": "/((?!.*\\.).*)", "destination": "/index.html" }
  ]
}
