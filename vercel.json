{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/tabulation", "destination": "/tabulation/", "permanent": false }
  ],
  "rewrites": [
    { "source": "/tabulation/", "destination": "/tabulation/index.html" },
    { "source": "/((?!.*\\.).*)", "destination": "/index.html" }
  ]
}
