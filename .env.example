# Firebase Web SDK config (SAFE to expose in the browser — these are public identifiers).
# Get these from: Firebase Console > Project Settings > General > "Your apps" > Web app > SDK setup and configuration > Config.
# Copy this file to `.env.local` and fill in the real values.
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=rom-database-0909.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=rom-database-0909
VITE_FIREBASE_STORAGE_BUCKET=rom-database-0909.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# --- Backend (optional) ---
# The deployed ROMIO API (see backend/README.md). Without it the app still works:
# in-app reminders only, and Pro is granted manually by a master.
VITE_API_BASE=https://your-project.vercel.app
# Web Push key, for reminders that arrive while ROMIO is closed.
# Firebase Console > Project settings > Cloud Messaging > Web Push certificates > Generate key pair
VITE_FIREBASE_VAPID_KEY=your-vapid-public-key
