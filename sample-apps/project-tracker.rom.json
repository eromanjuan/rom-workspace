{
  "format": "quest-hq-app",
  "version": 1,
  "app": {
    "name": "Project Tracker",
    "description": "Track web projects end to end: status, deadlines, budget and progress.",
    "type": "Projects",
    "icon": "ti-briefcase",
    "color": "#2563eb",
    "fields": [
      { "id": "f_project", "label": "Project name", "type": "text", "config": { "placeholder": "e.g. Acme website redesign" } },
      { "id": "f_client", "label": "Client", "type": "text", "config": {} },
      { "id": "f_status", "label": "Status", "type": "status", "config": { "options": [
        { "id": "s_plan", "label": "Planning", "color": "#6b7280" },
        { "id": "s_prog", "label": "In Progress", "color": "#2563eb" },
        { "id": "s_rev", "label": "Review", "color": "#d97706" },
        { "id": "s_block", "label": "Blocked", "color": "#dc2626" },
        { "id": "s_done", "label": "Done", "color": "#16a34a" }
      ] } },
      { "id": "f_priority", "label": "Priority", "type": "category", "config": { "options": [
        { "id": "p_low", "label": "Low", "color": "#6b7280" },
        { "id": "p_med", "label": "Medium", "color": "#2563eb" },
        { "id": "p_high", "label": "High", "color": "#d97706" },
        { "id": "p_urg", "label": "Urgent", "color": "#dc2626" }
      ] } },
      { "id": "f_start", "label": "Start date", "type": "date", "config": {} },
      { "id": "f_deadline", "label": "Deadline", "type": "date", "config": {} },
      { "id": "f_lead_time", "label": "Lead time", "type": "datediff", "config": { "startField": "f_start", "endField": "f_deadline" } },
      { "id": "f_progress", "label": "Progress", "type": "progress", "config": {} },
      { "id": "f_budget", "label": "Budget", "type": "money", "config": { "currency": "$" } },
      { "id": "f_lead", "label": "Project lead", "type": "user", "config": {} },
      { "id": "f_repo", "label": "Repository", "type": "url", "config": { "placeholder": "https://github.com/org/repo" } },
      { "id": "f_notes", "label": "Notes", "type": "richtext", "config": {} }
    ],
    "items": [],
    "automations": []
  }
}
