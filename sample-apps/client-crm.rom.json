{
  "rom_app": true,
  "version": 1,
  "name": "Client CRM",
  "description": "Manage clients and leads: pipeline stage, deal value and contact info.",
  "type": "Contacts",
  "icon": "address-book",
  "color": "#0d9488",
  "fields": [
    { "key": "name", "label": "Name", "type": "text", "config": { "placeholder": "Contact name" } },
    { "key": "company", "label": "Company", "type": "text", "config": { "placeholder": "Company" } },
    { "key": "email", "label": "Email", "type": "email", "config": {} },
    { "key": "phone", "label": "Phone", "type": "phone", "config": {} },
    { "key": "type", "label": "Type", "type": "category", "config": { "options": [
      { "label": "Lead", "color": "#d97706" },
      { "label": "Client", "color": "#16a34a" },
      { "label": "Partner", "color": "#2563eb" },
      { "label": "Vendor", "color": "#6b7280" }
    ] } },
    { "key": "stage", "label": "Stage", "type": "status", "config": { "options": [
      { "label": "Lead", "color": "#6b7280" },
      { "label": "Contacted", "color": "#2563eb" },
      { "label": "Proposal", "color": "#d97706" },
      { "label": "Won", "color": "#16a34a" },
      { "label": "Lost", "color": "#dc2626" }
    ] } },
    { "key": "deal_value", "label": "Deal value", "type": "money", "config": { "currency": "$" } },
    { "key": "website", "label": "Website", "type": "url", "config": { "placeholder": "https://…" } },
    { "key": "location", "label": "Location", "type": "location", "config": {} },
    { "key": "last_contact", "label": "Last contact", "type": "date", "config": {} },
    { "key": "notes", "label": "Notes", "type": "textarea", "config": { "placeholder": "Context, next steps…" } }
  ],
  "reports": [
    { "id": "r_stage", "title": "Contacts by stage", "groupBy": "stage", "metric": "count", "sumField": "" },
    { "id": "r_pipeline", "title": "Pipeline value by stage", "groupBy": "stage", "metric": "sum", "sumField": "deal_value" },
    { "id": "r_type", "title": "Contacts by type", "groupBy": "type", "metric": "count", "sumField": "" }
  ],
  "automations": [
    { "id": "a_won", "trigger": { "fieldKey": "stage", "op": "==", "value": "Won" }, "actions": [ { "type": "notify", "message": "Deal won: {Name} at {Company}" } ] }
  ]
}
