{
  "format": "quest-hq-app",
  "version": 1,
  "app": {
    "name": "Bug & Issue Tracker",
    "description": "Log bugs and feature requests with severity, environment and status.",
    "type": "Tickets",
    "icon": "ti-bug",
    "color": "#dc2626",
    "fields": [
      { "id": "f_ref", "label": "Ref", "type": "autonumber", "config": { "prefix": "BUG-", "pad": 3 } },
      { "id": "f_title", "label": "Title", "type": "text", "config": { "placeholder": "Short summary of the issue" } },
      { "id": "f_desc", "label": "Description", "type": "richtext", "config": {} },
      { "id": "f_type", "label": "Type", "type": "category", "config": { "options": [
        { "id": "t_bug", "label": "Bug", "color": "#dc2626" },
        { "id": "t_feat", "label": "Feature", "color": "#2563eb" },
        { "id": "t_task", "label": "Task", "color": "#0d9488" },
        { "id": "t_chore", "label": "Chore", "color": "#6b7280" }
      ] } },
      { "id": "f_labels", "label": "Labels", "type": "multiselect", "config": { "options": [
        { "id": "l_fe", "label": "Frontend", "color": "#2563eb" },
        { "id": "l_be", "label": "Backend", "color": "#0d9488" },
        { "id": "l_api", "label": "API", "color": "#7c3aed" },
        { "id": "l_ux", "label": "UX", "color": "#db2777" },
        { "id": "l_perf", "label": "Performance", "color": "#d97706" }
      ] } },
      { "id": "f_severity", "label": "Severity", "type": "status", "config": { "options": [
        { "id": "sv_crit", "label": "Critical", "color": "#dc2626" },
        { "id": "sv_high", "label": "High", "color": "#d97706" },
        { "id": "sv_med", "label": "Medium", "color": "#2563eb" },
        { "id": "sv_low", "label": "Low", "color": "#6b7280" }
      ] } },
      { "id": "f_status", "label": "Status", "type": "status", "config": { "options": [
        { "id": "st_open", "label": "Open", "color": "#6b7280" },
        { "id": "st_prog", "label": "In Progress", "color": "#2563eb" },
        { "id": "st_rev", "label": "In Review", "color": "#d97706" },
        { "id": "st_res", "label": "Resolved", "color": "#16a34a" },
        { "id": "st_closed", "label": "Closed", "color": "#4f46e5" }
      ] } },
      { "id": "f_env", "label": "Environment", "type": "category", "config": { "options": [
        { "id": "e_prod", "label": "Production", "color": "#dc2626" },
        { "id": "e_stage", "label": "Staging", "color": "#d97706" },
        { "id": "e_local", "label": "Local", "color": "#16a34a" }
      ] } },
      { "id": "f_assignee", "label": "Assignee", "type": "user", "config": {} },
      { "id": "f_reported", "label": "Reported on", "type": "date", "config": {} },
      { "id": "f_estimate", "label": "Estimate", "type": "number", "config": { "unit": "hrs" } },
      { "id": "f_steps", "label": "Steps to reproduce", "type": "textarea", "config": { "placeholder": "1. …\n2. …\n3. …" } },
      { "id": "f_link", "label": "Link", "type": "url", "config": { "placeholder": "PR, ticket or reference" } }
    ],
    "items": [],
    "automations": []
  }
}
