{
  "format": "quest-hq-app",
  "version": 1,
  "app": {
    "name": "Time & Deliverables Log",
    "description": "Log hours and deliverables per project for billing and reporting.",
    "type": "Records",
    "icon": "ti-clipboard-check",
    "color": "#d97706",
    "fields": [
      { "id": "f_summary", "label": "Task summary", "type": "text", "config": { "placeholder": "What did you work on?" } },
      { "id": "f_project", "label": "Project", "type": "text", "config": { "placeholder": "Related project" } },
      { "id": "f_date", "label": "Date", "type": "date", "config": {} },
      { "id": "f_hours", "label": "Hours", "type": "number", "config": { "unit": "hrs" } },
      { "id": "f_rate", "label": "Rate", "type": "money", "config": { "currency": "$" } },
      { "id": "f_amount", "label": "Amount", "type": "calculation", "config": { "formula": "{Hours} * {Rate}" } },
      { "id": "f_category", "label": "Category", "type": "category", "config": { "options": [
        { "id": "k_dev", "label": "Development", "color": "#2563eb" },
        { "id": "k_design", "label": "Design", "color": "#7c3aed" },
        { "id": "k_meet", "label": "Meeting", "color": "#6b7280" },
        { "id": "k_qa", "label": "QA", "color": "#0d9488" },
        { "id": "k_deploy", "label": "Deployment", "color": "#dc2626" },
        { "id": "k_admin", "label": "Admin", "color": "#d97706" }
      ] } },
      { "id": "f_billable", "label": "Billable", "type": "checkbox", "config": {} },
      { "id": "f_status", "label": "Status", "type": "status", "config": { "options": [
        { "id": "z_draft", "label": "Draft", "color": "#6b7280" },
        { "id": "z_sub", "label": "Submitted", "color": "#2563eb" },
        { "id": "z_appr", "label": "Approved", "color": "#16a34a" },
        { "id": "z_inv", "label": "Invoiced", "color": "#4f46e5" }
      ] } },
      { "id": "f_deliverable", "label": "Deliverable link", "type": "url", "config": { "placeholder": "Demo, doc or PR" } }
    ],
    "items": [],
    "automations": []
  }
}
