{
  "format": "quest-hq-app",
  "version": 1,
  "app": {
    "name": "Feature Backlog",
    "description": "Prioritize product ideas — showcases the new field types (auto-number, tags, rating, rich text, days-between, calculation).",
    "type": "Records",
    "icon": "ti-bulb",
    "color": "#7c3aed",
    "fields": [
      { "id": "f_ref", "label": "Ref", "type": "autonumber", "config": { "prefix": "FR-", "pad": 3 } },
      { "id": "f_title", "label": "Title", "type": "text", "config": { "placeholder": "Feature idea" } },
      { "id": "f_details", "label": "Details", "type": "richtext", "config": {} },
      { "id": "f_tags", "label": "Tags", "type": "multiselect", "config": { "options": [
        { "id": "g_fe", "label": "Frontend", "color": "#2563eb" },
        { "id": "g_be", "label": "Backend", "color": "#0d9488" },
        { "id": "g_api", "label": "API", "color": "#7c3aed" },
        { "id": "g_ux", "label": "UX", "color": "#db2777" },
        { "id": "g_infra", "label": "Infra", "color": "#6b7280" },
        { "id": "g_docs", "label": "Docs", "color": "#d97706" }
      ] } },
      { "id": "f_impact", "label": "Impact", "type": "rating", "config": { "max": 5 } },
      { "id": "f_effort", "label": "Effort", "type": "number", "config": { "unit": "days" } },
      { "id": "f_score", "label": "Score", "type": "calculation", "config": { "formula": "{Impact} * 10 - {Effort}" } },
      { "id": "f_status", "label": "Status", "type": "status", "config": { "options": [
        { "id": "s_idea", "label": "Idea", "color": "#6b7280" },
        { "id": "s_plan", "label": "Planned", "color": "#2563eb" },
        { "id": "s_build", "label": "Building", "color": "#d97706" },
        { "id": "s_ship", "label": "Shipped", "color": "#16a34a" },
        { "id": "s_rej", "label": "Rejected", "color": "#dc2626" }
      ] } },
      { "id": "f_requested", "label": "Requested", "type": "date", "config": {} },
      { "id": "f_target", "label": "Target", "type": "date", "config": {} },
      { "id": "f_lead_time", "label": "Lead time", "type": "datediff", "config": { "startField": "f_requested", "endField": "f_target" } }
    ],
    "items": [],
    "automations": []
  }
}
