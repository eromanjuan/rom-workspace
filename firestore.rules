rules_version = '2';

// ROM security model
// -------------------
// Feed:       every signed-in user can read all posts; you may only write your own.
// Workspaces: only members can read a workspace; only the owner can rename/delete it.
// Roles:      owner (full), editor (read+write), viewer (read only) — stored per member.
// Invites:    a signed-in user joins a workspace by presenting a matching invite (by id + email).
// Apps:       the "app builder" — apps and their records live under a workspace and follow its roles.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // The master / super-admin account — full access everywhere. Either the
    // original hardcoded account OR anyone a master has promoted (isMaster flag
    // on their user doc; users can't set that field on themselves, see below).
    function isMaster() {
      return signedIn() && (
        request.auth.token.email == 'eugenioiromanjuan@gmail.com'
        || (exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isMaster == true)
      );
    }

    // The ORIGINAL super-admin (the hardcoded email). Only they may suspend or
    // delete a master account, or promote/demote master — promoted masters can't
    // act on each other or on the primary.
    function isPrimaryMaster() {
      return signedIn() && request.auth.token.email == 'eugenioiromanjuan@gmail.com';
    }
    // Is the user doc being written currently a master account?
    function targetUserIsMaster() {
      return resource.data.isMaster == true
        || (resource.data.email is string
            && resource.data.email.lower() == 'eugenioiromanjuan@gmail.com');
    }
    function userUpdateTouches(field) {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([field]);
    }
    // A master's update to someone else's user doc, with the master-protection
    // guard: promoting/demoting master, and suspending/deleting a master account,
    // are restricted to the primary master.
    function masterUserUpdateAllowed() {
      return isMaster()
        && (!userUpdateTouches('isMaster') || isPrimaryMaster())
        && ((!userUpdateTouches('suspended') && !userUpdateTouches('deleted'))
            || !targetUserIsMaster() || isPrimaryMaster());
    }

    // --- workspace membership helpers ---
    function memberPath(wsId) {
      return /databases/$(database)/documents/workspaces/$(wsId)/members/$(request.auth.uid);
    }
    function isMember(wsId) {
      return signedIn() && exists(memberPath(wsId));
    }
    function myRole(wsId) {
      return get(memberPath(wsId)).data.role;
    }
    function canWrite(wsId) {
      // master, owner and editor may write; a custom member may write if their
      // stored `writer` flag is true (set when granted any create capability);
      // viewer may not.
      return isMaster() || (isMember(wsId) && (
        myRole(wsId) in ['owner', 'editor']
        || get(memberPath(wsId)).data.writer == true
      ));
    }
    function isOwner(wsId) {
      return isMaster() || (isMember(wsId) && myRole(wsId) == 'owner');
    }

    // --- user profiles ---
    match /users/{uid} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == uid;
      // A user may edit their own profile but NOT the privileged admin fields
      // (isMaster/suspended/deleted) — only a master can set those on anyone.
      // Self-branch is checked first so ordinary edits don't pay for a get().
      allow update: if signedIn() && (
        (request.auth.uid == uid
         && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isMaster', 'suspended', 'deleted', 'pro', 'proUntil']))
        // A user may tombstone their OWN account (Google Play self-serve deletion):
        // set deleted=true and scrub personal fields — nothing else, and never un-delete.
        || (request.auth.uid == uid
            && request.resource.data.deleted == true
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['deleted', 'deletedAt', 'bio', 'phone', 'photoURL', 'links', 'username']))
        // Masters manage others — but only the primary master may suspend/delete
        // a master or change the isMaster flag.
        || (request.auth.uid != uid && masterUserUpdateAllowed())
      );
      // Hard-deleting a master's user doc is primary-master only (the app doesn't
      // hard-delete anyway — this is defence in depth).
      allow delete: if isMaster() && (isPrimaryMaster() || !targetUserIsMaster());

      // per-user subcollections (widgets, events, checklists, notes, …) — owner (or master) only
      match /{sub}/{docId} {
        allow read, write: if signedIn() && (request.auth.uid == uid || isMaster());
      }
    }

    // --- notifications (per-user inbox) ---
    // A signed-in user may create a notification addressed to another user (e.g.
    // a like/comment/join event) but must stamp themselves as the actor, so a
    // notification can't be forged to look like it came from someone else. Only
    // the recipient (or master) can read, mark read, or delete their own.
    match /notifications/{uid}/items/{nid} {
      allow read, update, delete: if signedIn() && (request.auth.uid == uid || isMaster());
      allow create: if signedIn()
                    && request.resource.data.actorId == request.auth.uid
                    && (!('title' in request.resource.data) || request.resource.data.title.size() <= 300)
                    && (!('body' in request.resource.data)  || request.resource.data.body.size()  <= 500);
    }

    // --- activity log (audit trail) ---
    // Anyone signed in records their OWN actions (self-stamped actor). The master
    // reads the whole trail; everyone else can only read their own entries.
    // Entries are immutable — only the master may clear them.
    match /activityLog/{id} {
      allow create: if signedIn() && request.resource.data.actorId == request.auth.uid;
      allow read: if isMaster() || (signedIn() && resource.data.actorId == request.auth.uid);
      allow update, delete: if isMaster();
    }

    // --- bug reports / feedback ---
    // Any signed-in user may file a report (stamped with themselves as sender);
    // only the master can read the inbox, mark reports resolved, or delete them.
    match /reports/{id} {
      allow create: if signedIn()
                    && request.resource.data.fromUid == request.auth.uid
                    && request.resource.data.message is string
                    && request.resource.data.message.size() <= 4000;
      allow read, update, delete: if isMaster();
    }

    // Master-only collection-group read over ALL chat messages, so the control
    // panel's message search can look across every conversation. (Normal per-
    // conversation reads are still governed by the member rule below; this extra
    // recursive rule only ADDS master access and is required because a
    // collectionGroup query isn't covered by the nested messages rule.)
    match /{path=**}/messages/{msgId} {
      allow read: if isMaster();
    }

    // --- VESSCORE tabulation (embedded standalone app at /tabulation) ---
    // The master (admin) is a signed-in ROMIO master. Judges sign in via Firebase
    // ANONYMOUS auth on load, then enter a passkey inside the app. Requiring
    // signedIn() (which anonymous auth satisfies) closes the previous hole where
    // these collections were writable by any unauthenticated internet client.
    // NOTE: this stops drive-by/REST tampering but a determined actor can still
    // script an anonymous session; the full fix is server-side passkey validation
    // (Vercel function writing with the Admin SDK) — planned as a follow-up.
    match /categories/{id}  { allow read: if signedIn(); allow write: if isMaster(); }
    match /candidates/{id}  { allow read: if signedIn(); allow write: if isMaster(); }
    match /criteria/{id}    { allow read: if signedIn(); allow write: if isMaster(); }
    match /judges/{id}      { allow read: if signedIn(); allow write: if isMaster(); }
    match /scores/{id}      { allow read: if signedIn(); allow create, update: if signedIn(); allow delete: if isMaster(); }
    match /judge_syncs/{id} { allow read, write: if signedIn(); }
    // Score locks: a judge may LOCK their sheet (locked==true); only the master
    // can UNLOCK (locked==false) — that's how access requests are granted.
    match /score_locks/{id} {
      allow read: if signedIn();
      allow create, update: if isMaster() || (signedIn() && request.resource.data.locked == true);
      allow delete: if isMaster();
    }
    // Access requests + the score-change log: signed-in judges create; only the
    // master can resolve/clear them.
    match /score_requests/{id} { allow read: if signedIn(); allow create: if signedIn(); allow update, delete: if isMaster(); }
    match /score_logs/{id}     { allow read: if signedIn(); allow create: if signedIn(); allow update, delete: if isMaster(); }
    // Shared theme (and any app settings): signed-in reads, only master writes.
    match /settings/{id}    { allow read: if signedIn(); allow write: if isMaster(); }

    // --- chat: conversations (direct + workspace groups) and their messages ---
    // A conversation is readable/writable only by its members. Any member may
    // update it (post lastMessage, add members). Messages are member-only and
    // immutable once sent.
    match /conversations/{convId} {
      // get: allow probing a non-existent conversation (so "does this DM exist?"
      // works before creating it); an existing one is readable only by members.
      allow get: if signedIn() && (resource == null || request.auth.uid in resource.data.members);
      // list: the query is constrained to members array-contains me, so every
      // returned doc must have me as a member.
      allow list: if signedIn() && request.auth.uid in resource.data.members;
      allow create: if signedIn() && request.auth.uid in request.resource.data.members;
      allow update: if signedIn() && request.auth.uid in resource.data.members;

      match /messages/{msgId} {
        allow read: if signedIn()
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.members;
        allow create: if signedIn()
                      && request.resource.data.senderId == request.auth.uid
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.members;
        allow update, delete: if false;
      }
    }

    // --- unique usernames (handles) ---
    // The doc id IS the lowercased handle, so a create can only succeed once →
    // uniqueness. Public read so availability can be checked before sign-up.
    match /usernames/{handle} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && (resource.data.uid == request.auth.uid || isMaster());
      allow update: if false; // handles are immutable; a change = delete + create
    }

    // --- embedded Workspace Builder module state ---
    // One doc per workspace (docId == wsId) holds that workspace's builder blob,
    // plus a personal fallback doc `u-{uid}` and a legacy `shared` migration doc.
    // Access follows workspace membership so a non-member can't read or clobber
    // another workspace's builder state (docId is the wsId).
    match /workspaceBuilder/{docId} {
      allow read: if signedIn() && (
        docId == 'shared' || docId == ('u-' + request.auth.uid)
        || isMember(docId) || isMaster()
      );
      allow write: if signedIn() && (
        docId == 'shared' || docId == ('u-' + request.auth.uid)
        || canWrite(docId) || isMaster()
      );
    }

    // --- ROM App Market (shared app definitions, browsable by anyone) ---
    match /appMarket/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.publishedBy == request.auth.uid;
      allow delete: if signedIn() && (resource.data.publishedBy == request.auth.uid || isMaster());
    }

    // --- uploaded files (metadata; the blobs live in Storage) ---
    match /files/{fileId} {
      allow read: if signedIn() && (resource.data.ownerId == request.auth.uid || isMaster());
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      // Update powers Trash (soft-delete / restore). Owner or master only, and the
      // file's ownerId can never change.
      allow update: if signedIn() && (resource.data.ownerId == request.auth.uid || isMaster())
                    && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if signedIn() && (resource.data.ownerId == request.auth.uid || isMaster());
    }

    // --- global feed ---
    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn()
                    && request.resource.data.authorId == request.auth.uid
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 4000;
      // authors manage their own posts; the master can moderate any post
      allow delete: if signedIn() && (resource.data.authorId == request.auth.uid || isMaster());
      // updates: the author (or master) may change anything (edit text, etc.);
      // any signed-in user may ONLY toggle likes / comments / pollVotes (react,
      // comment, vote in a poll).
      allow update: if signedIn() && (
        resource.data.authorId == request.auth.uid || isMaster()
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'comments', 'pollVotes'])
      );
    }

    // Collection-group read for "list my workspaces": the app runs
    // collectionGroup('members').where('uid','==',me). A collectionGroup query
    // is NOT covered by the nested workspaces/{wsId}/members rule below — it
    // needs this recursive-wildcard rule. Keyed on the `uid` field so the query
    // is statically provable. (Writes are still governed by the nested rule.)
    match /{path=**}/members/{memberUid} {
      allow read: if resource.data.uid == request.auth.uid;
    }

    // --- workspaces ---
    match /workspaces/{wsId} {
      // The workspace DOC (name/desc/icon/owner) is readable by any signed-in
      // user so workspaces can be discovered + searched to request joining. The
      // sensitive subcollections (members, feed, apps, tiles) keep member-only
      // rules below, so this only exposes basic identity, not content.
      allow read: if signedIn();
      // creating a workspace: you must set yourself as the owner
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      // only the owner (or master) may rename or delete the workspace
      allow update, delete: if isOwner(wsId);

      // --- join requests (user asks to join; owner approves) ---
      match /joinRequests/{reqUid} {
        allow read: if request.auth.uid == reqUid || isOwner(wsId);
        allow create: if signedIn() && request.auth.uid == reqUid
                      && request.resource.data.uid == reqUid;
        allow delete: if request.auth.uid == reqUid || isOwner(wsId);
        allow update: if isOwner(wsId);
      }

      // --- members (the role table) ---
      match /members/{memberUid} {
        // Reading own membership is keyed on the `uid` FIELD (not the doc id) so
        // that the collectionGroup query `where('uid','==',me)` used by
        // "list my workspaces" is statically provable and permitted. Members can
        // read the whole roster; master reads everything.
        allow read: if isMember(wsId) || isMaster();

        // 0) the workspace owner (or master) adding any user directly
        // 1) the workspace owner creating their own owner membership at setup time
        // 2) a user accepting an invite that matches their email + the requested role
        allow create: if isOwner(wsId) || (signedIn() && request.auth.uid == memberUid && (
          get(/databases/$(database)/documents/workspaces/$(wsId)).data.ownerId == request.auth.uid
          || (
            request.resource.data.inviteId is string
            && exists(/databases/$(database)/documents/invites/$(request.resource.data.inviteId))
            && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteId)).data.workspaceId == wsId
            && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteId)).data.email == request.auth.token.email
            && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteId)).data.role == request.resource.data.role
            && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteId)).data.status == 'pending'
          )
        ));

        // owner manages roles; a member may remove themselves (leave)
        allow update: if isOwner(wsId);
        allow delete: if isOwner(wsId) || request.auth.uid == memberUid;
      }

      // --- workspace activity feed (the builder home) ---
      match /feed/{postId} {
        allow read: if isMember(wsId) || isMaster();
        allow create: if canWrite(wsId) && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if signedIn() && (resource.data.authorId == request.auth.uid || isOwner(wsId));
      }

      // --- dashboard tiles (the no-code dashboard) ---
      match /tiles/{tileId} {
        allow read: if isMember(wsId) || isMaster();
        allow create, update, delete: if canWrite(wsId);
      }

      // --- workspace tasks (used by the Tasks tile) ---
      match /tasks/{taskId} {
        allow read: if isMember(wsId) || isMaster();
        allow create, update, delete: if canWrite(wsId);
      }

      // --- shared calendar events + checklists (view: members; edit: canWrite) ---
      match /events/{eventId} {
        allow read: if isMember(wsId) || isMaster();
        allow create, update, delete: if canWrite(wsId);
      }
      match /checklists/{listId} {
        allow read: if isMember(wsId) || isMaster();
        allow create, update, delete: if canWrite(wsId);
      }
      match /notes/{noteId} {
        allow read: if isMember(wsId) || isMaster();
        allow create, update, delete: if canWrite(wsId);
      }

      // --- app builder: apps + their records follow workspace roles ---
      match /apps/{appId} {
        allow read: if isMember(wsId) || isMaster();
        allow create, update, delete: if canWrite(wsId);

        match /records/{recordId} {
          allow read: if isMember(wsId);
          allow create, update, delete: if canWrite(wsId);
        }
      }
    }

    // --- invites ---
    match /invites/{inviteId} {
      // Read is scoped so invite emails (PII) aren't exposed to everyone: the
      // invitee reads their own invite (email match, lowercased at write time),
      // and a workspace's owner/editor can list its invites. Works for both the
      // get-by-id accept flow and the where('workspaceId','==',ws) list query.
      allow read: if signedIn() && (
        resource.data.email == request.auth.token.email.lower()
        || canWrite(resource.data.workspaceId)
        || isMaster()
      );
      // only owner/editor of the target workspace may invite people
      allow create: if signedIn()
                    && canWrite(request.resource.data.workspaceId)
                    && request.resource.data.role in ['editor', 'viewer'];
      // owner can revoke; the accepting user flips status to 'accepted'
      allow update: if signedIn() && (
        isOwner(resource.data.workspaceId)
        || (resource.data.email == request.auth.token.email
            && request.resource.data.status == 'accepted')
      );
      allow delete: if signedIn() && isOwner(resource.data.workspaceId);
    }
  }
}
